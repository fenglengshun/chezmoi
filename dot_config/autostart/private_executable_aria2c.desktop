[Desktop Entry]
Comment[en_US]=
Comment=
Exec=/bin/bash -c '/usr/bin/aria2c --enable-rpc --rpc-secret $(cat /home/fenglengshun/.config/aria2-secret) --save-session=/home/fenglengshun/.local/share/aria2c-session --save-session-interval=10 --force-save=true --save-not-found=true'
GenericName[en_US]=
GenericName=
Icon=
MimeType=
Name[en_US]=aria2c
Name=aria2c
StartupNotify=true
Terminal=false
TerminalOptions=
Type=Application
X-KDE-SubstituteUID=false
X-KDE-Username=
